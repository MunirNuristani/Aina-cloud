# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
POSTGRES_URL="postgresql://postgres:yourpassword@localhost:5432/aina-backend"

# Secret string appended to device API keys before bcrypt hashing.
# Generate a strong random value: openssl rand -hex 32
DEVICE_API_KEY_PEPPER="change-me-to-a-long-random-secret"

# OpenWeatherMap API key (optional).
# If omitted, weather data will not be attached to readings.
# Free tier at https://openweathermap.org/api
OPENWEATHER_API_KEY=""

# Development only — set to "true" to skip device key verification.
# Never enable this in production.
DEV_BYPASS_AUTH=""
